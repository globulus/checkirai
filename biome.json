{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "files": {
    "includes": [
      "src/**",
      "web/src/**",
      "web/index.html",
      "web/vite.config.ts",
      "bin/**",
      "docs/**",
      "test/**",
      "package.json",
      "biome.json",
      "tsconfig.json",
      "README.md"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "lineWidth": 80
    }
  }
}
